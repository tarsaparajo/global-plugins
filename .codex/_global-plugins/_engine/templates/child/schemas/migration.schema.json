{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Migration",
  "type": "object",
  "required": ["migration", "from", "reversible", "steps"],
  "properties": {
    "migration": { "type": "string" },
    "from": { "type": "string" },
    "breakingFor": { "type": "array", "items": { "enum": ["products", "projects", "substrates"] } },
    "appliesWhen": { "type": "array" },
    "reversible": { "type": "boolean" },
    "estimatedRisk": { "enum": ["low", "medium", "high"] },
    "steps": {
      "type": "array",
      "description": "Structured steps the runner (scripts/evolve/migrate-apply.mjs) interprets by `kind`, never a shell string. Supported kinds: relocate-nonstandard-dirs (move PRIVATE top-level dirs into _<slug>/<dir>/, classified by the engine), remove-path (delete provider-root-relative paths if present).",
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "enum": ["relocate-nonstandard-dirs", "remove-path"] },
          "scope": { "type": "array", "items": { "type": "string" } },
          "paths": { "type": "array", "items": { "type": "string" } },
          "onlyWhen": { "enum": ["bundleExists"] }
        }
      }
    }
  }
}
