{
  "description": "Post-session reminder to validate a freshly generated or adapted plugin.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/suggest-validate.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
